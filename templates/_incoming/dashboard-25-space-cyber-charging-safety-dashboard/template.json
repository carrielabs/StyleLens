    "textEdit": true,
    "inlineContentEditable": true,
    "chartDataInjection": true,
    "excelSlotMapping": true,
    "showHideSections": true,
    "themeOverride": false
  },
  "supportedSections": {
    "key-takeaway": {
      "desc": "平台标题、四大底座指标和今日安全综述",
      "required": true,
      "hideable": false
    },
    "core-finding-1": {
      "desc": "智能充电端口分布、每日充电能耗趋势和注册车辆增长曲线",
      "required": true,
      "hideable": true
    },
    "core-finding-2": {
      "desc": "实时火灾安全预警、告警站点、视频源、时间戳、位置和监控网格",
      "required": true,
      "hideable": true
    },
    "core-finding-3": {
      "desc": "隐患流转、综合效能、时段热力、充电分布和能耗损耗分析",
      "required": false,
      "hideable": true
    }
  },
  "supportedChartTypes": [
    "ring-pie",
    "column-bar",
    "smooth-line-area",
    "funnel",
    "radar",
    "heatmap",
    "scatter",
    "waterfall"
  ],
  "schema": {
    "editableText": {
      "type": "array",
      "selector": "[data-editable=\"true\"]",
      "desc": "所有可编辑文字均带 data-editable、contenteditable、data-slot 和 data-key"
    },
    "charts": {
      "type": "array",
      "selector": "[id^=\"chart-\"]",
      "desc": "8 个 ECharts 图表容器"
    },
    "sections": {
      "type": "array",
      "selector": "[data-section]",
      "desc": "4 个核心数据区"
    },
    "textSlots": [
      "text.platformTitle",
      "text.totalStations",
      "text.totalPorts",
      "text.totalVehicles",
      "text.totalUsage",
      "text.takeawaySummary",
      "text.finding1Title",
      "text.finding2Title",
      "text.alarmStation",
      "text.alarmTime",
      "text.alarmLocation"
    ]
  },
  "chartModules": [
    { "id": "chart-port-status-ring", "type": "ring-pie", "section": "core-finding-1", "description": "智能充电端口使用率分布" },
    { "id": "chart-daily-power-bar", "type": "column-bar", "section": "core-finding-1", "description": "每日充电量趋势柱状图" },
    { "id": "chart-vehicle-trend-area", "type": "smooth-line-area", "section": "core-finding-1", "description": "累计新增注册车辆趋势面积图" },
    { "id": "chart-fault-funnel", "type": "funnel", "section": "core-finding-3", "description": "安全隐患治理流转漏斗" },
    { "id": "chart-station-radar", "type": "radar", "section": "core-finding-3", "description": "充电站综合效能雷达图" },
    { "id": "chart-peak-heatmap", "type": "heatmap", "section": "core-finding-3", "description": "充电时段热力分布图" },
    { "id": "chart-duration-scatter", "type": "scatter", "section": "core-finding-3", "description": "单次充电时长与充电量分布" },
    { "id": "chart-energy-waterfall", "type": "waterfall", "section": "core-finding-3", "description": "月度能耗损耗分摊瀑布图" }
  ],
