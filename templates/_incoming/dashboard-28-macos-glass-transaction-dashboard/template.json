    }
  },
  "editableCapabilities": {
    "textEdit": true,
    "inlineContentEditable": true,
    "chartDataInjection": true,
    "excelSlotMapping": true,
    "showHideSections": true,
    "themeOverride": false,
    "systemThemeSync": true
  },
  "supportedSections": {
    "key-takeaway": {
      "desc": "顶部品牌、三条核心洞察和四个 KPI 指标",
      "required": true,
      "hideable": false
    },
    "core-finding-1": {
      "desc": "流量热力点阵和渠道嵌套圆环",
      "required": true,
      "hideable": true
    },
    "core-finding-2": {
      "desc": "时间区间波形和年度趋势面积折线",
      "required": true,
      "hideable": true
    },
    "core-finding-3": {
      "desc": "渠道胶囊对比和边缘节点延迟状态",
      "required": true,
      "hideable": true
    }
  },
  "supportedChartTypes": [
    "kpi",
    "heatmap",
    "ring",
    "column",
    "area",
    "capsule-bar",
    "latency"
  ],
  "sourceSupportedChartTypes": [
    "kpi",
    "funnel",
    "heatmap",
    "ring",
    "radar",
    "line",
    "area",
    "column",
    "stacked-column",
    "waterfall",
    "ranking",
    "latency"
  ],
  "schema": {
    "editableText": {
      "type": "array",
      "selector": "[data-editable=\"true\"]",
      "desc": "所有可编辑文字均带 data-editable、contenteditable、data-slot 和 data-key"
    },
    "charts": {
      "type": "array",
      "selector": "[data-chart-type], [id^=\"chart-\"]",
      "desc": "实际 10 个 chart-* 图表/数据模块"
    },
    "sections": {
      "type": "array",
      "selector": "[data-section]",
      "desc": "4 类核心数据区，部分区内有多个图表模块"
    },
    "textSlots": [
      "text.brand_title",
      "text.brand_sub",
      "text.insight_1_title",
      "text.insight_1_desc",
      "text.insight_2_title",
      "text.insight_2_desc",
      "text.insight_3_title",
      "text.insight_3_desc",
      "text.finding_1_title",
      "text.finding_1_desc",
      "text.finding_2_title",
      "text.finding_2_desc",
      "text.finding_3_title",
      "text.finding_3_desc"
    ]
  },
  "chartModules": [
    { "id": "chart-net-revenue-kpi", "type": "kpi", "section": "key-takeaway", "description": "总交易净额指标卡" },
    { "id": "chart-transaction-volume-kpi", "type": "kpi", "section": "key-takeaway", "description": "事务处理总量指标卡" },
    { "id": "chart-promo-revenue-kpi", "type": "kpi", "section": "key-takeaway", "description": "广告投放总收益指标卡" },
    { "id": "chart-edge-availability-kpi", "type": "kpi", "section": "key-takeaway", "description": "全球节点可用性指标卡" },
    { "id": "chart-traffic-heatmap", "type": "heatmap", "section": "core-finding-1", "description": "流量热力点阵" },
    { "id": "chart-channel-nested-ring", "type": "ring", "section": "core-finding-1", "description": "渠道多维嵌套圆环" },
    { "id": "chart-time-range-wave", "type": "column", "section": "core-finding-2", "description": "时间区间波形柱状调节器" },
    { "id": "chart-annual-trend-area", "type": "area", "section": "core-finding-2", "description": "年度趋势面积折线图" },
    { "id": "chart-channel-capsule-comparison", "type": "capsule-bar", "section": "core-finding-3", "description": "渠道胶囊对比图" },
    { "id": "chart-edge-latency-status", "type": "latency", "section": "core-finding-3", "description": "边缘节点延迟状态" }
  ],
