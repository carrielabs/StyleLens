    "financial-review",
    "digital-settlement-screen"
  ],
  "styleTags": [
    "glassmorphism",
    "macos-style",
    "premium-dashboard",
    "interactive-hover",
    "transaction-analytics"
  ],
  "deliveryType": "single-page-dashboard",
  "interactionMode": "editable-dashboard",
  "contentCapacity": "high",
  "bestFor": [
    "数字化交易分析大屏",
    "跨境收单与清结算复盘",
    "渠道流量热力分析",
    "API 边缘节点监控",
    "企业经营数据可视化"
  ],
  "requiredRuntime": [
    "Tailwind CDN",
    "Lucide CDN",
    "Vanilla JavaScript"
  ],
  "theme": {
    "colors": {
      "background": "#F0F4FF",
      "surfaceGlass": "rgba(255, 255, 255, 0.48)",
