      "required": true,
      "hideable": true
    },
    "market-architecture": {
      "desc": "SiPh 市场渗透率曲线与 EML / SiPh 芯片架构连接图对比",
      "required": true,
      "hideable": false
    },
    "bottom-insights": {
      "desc": "Why SiPh 勋章功能条、核心结论与 TAM 五线折线预测图",
      "required": true,
      "hideable": false
