{
  "id": "website-03-red-clay",
  "name": "红土风格官网模板",
  "templateName": "RedClayTennisClubPremiumTemplate",
  "version": "2.2.0",
  "description": "极具情绪张力与粉笔手绘质感的顶级网球俱乐部全漏斗官网模板，零外部依赖，内置 SVG 位移噪点与全局沙粒物理图层。",
  "pageTypes": [
    "product-website",
    "landing-page",
    "sports-club",
    "brand-site"
  ],
  "styleTags": [
    "red-clay",
    "tennis",
    "brutalism",
    "poster",
    "chalk",
    "fine-art"
  ],
  "theme": {
    "colors": {
      "clay": "#B73E23",
      "chalk": "#FDF9F1",
      "neon": "#D9EB26",
      "net": "#1C1514"
    },
    "fonts": {
      "mega": "Chivo, Arial Black, Impact, sans-serif",
      "body": "Noto Sans SC, sans-serif"
    }
  },
  "editableCapabilities": {
    "textEdit": true,
    "showHideSections": true,
    "customCursor": true,
    "exportHtml": true
  },
  "supportedSections": {
    "hero": {
      "name": "巨型海报首屏",
      "desc": "展示品牌冲击力和赛事属性，带有巨幅对撞排版标语。",
      "required": true,
      "hideable": false,
      "elementCount": 6
    },
    "statement": {
      "name": "核心价值观宣言",
      "desc": "俱乐部品牌态度阐释，大留白、超大字号展示。",
      "required": false,
      "hideable": true,
      "elementCount": 1
    },
    "problem": {
      "name": "用户现状痛点",
      "desc": "粉笔横向画线擦除样式，列举用户当前的球技或硬件瓶颈。",
      "required": false,
      "hideable": true,
      "elementCount": 10
    },
    "solutions": {
      "name": "核心解决方案",
      "desc": "手绘粉笔圆圈排印样式，列举针对痛点的颠覆式服务。",
      "required": false,
      "hideable": true,
      "elementCount": 9
    },
    "academy": {
      "name": "集训课程阵容",
      "desc": "俱乐部核心课程板块，配有鼠标 Hover 飞出黄色网球动效。",
      "required": false,
      "hideable": true,
      "elementCount": 7
    },
    "facilities": {
      "name": "顶级场地设施",
      "desc": "俱乐部核心硬件条件罗列。",
      "required": false,
      "hideable": true,
      "elementCount": 8
    },
    "workflow": {
      "name": "加入成长流程",
      "desc": "手绘战术虚线连结样式，描绘用户的进阶路线图。",
      "required": false,
      "hideable": true,
      "elementCount": 9
    },
    "cta": {
      "name": "行动呼吁与赛点",
      "desc": "赛点转化模块，引导用户预约订场或联系我们。",
      "required": true,
      "hideable": false,
      "elementCount": 5
    },
    "footer": {
      "name": "社媒巨型页脚",
      "desc": "俱乐部全社媒展示、小程序引流、手绘二维码占位区。",
      "required": true,
      "hideable": false,
      "elementCount": 10
    }
  },
