    "duplicateSlotCount": 0,
    "dataSectionElementCount": 3,
    "uniqueDataSectionCount": 3,
    "chartCount": 8,
    "kpiCount": 4,
    "chartLibrary": "ECharts",
    "usesTailwindCdn": true,
