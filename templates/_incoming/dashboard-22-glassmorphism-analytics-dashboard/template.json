{
  "id": "dashboard-22-glassmorphism-analytics-dashboard",
  "name": "Glassmorphism Analytics Dashboard 国际范毛玻璃数据分析看板",
  "templateName": "GlassmorphismAnalyticsDashboardTemplate",
  "version": "1.0.0",
  "description": "面向存储用量、文件访问和活动趋势分析的浅色毛玻璃数据 Dashboard，支持 240 度 KPI 仪表盘、180 度趋势仪表盘和 DOM 分段条形图。",
  "pageTypes": [
    "dashboard",
    "data-report",
    "analytics",
    "business-review"
  ],
  "styleTags": [
    "glassmorphism",
    "modern-dashboard",
    "light-analytics",
    "storage-report",
    "echarts"
  ],
  "deliveryType": "single-page-dashboard",
  "interactionMode": "editable-dashboard",
  "contentCapacity": "medium",
  "bestFor": [
    "存储用量分析",
    "文件访问统计",
    "活动趋势报告",
    "轻量级运营看板",
    "B 端数据汇报"
  ],
  "requiredRuntime": [
    "Tailwind CSS CDN",
    "ECharts CDN",
    "Vanilla JavaScript"
  ],
  "theme": {
    "colors": {
      "primary": "#3B82F6",
      "background": "#F0F4F8",
      "surface": "rgba(255, 255, 255, 0.75)",
      "textMain": "#111827",
      "textSub": "#6B7280",
      "textMuted": "#9CA3AF",
      "blue": "#3B82F6",
      "green": "#10B981",
      "orange": "#F59E0B",
      "purple": "#8B5CF6"
    },
    "fonts": {
      "body": "Inter, -apple-system, BlinkMacSystemFont, Segoe UI, Roboto, Helvetica Neue, Arial, sans-serif"
    }
  },
  "editableCapabilities": {
    "textEdit": true,
    "inlineContentEditable": true,
    "chartDataInjection": true,
    "excelSlotMapping": true,
    "showHideSections": true,
    "themeOverride": false
  },
  "supportedSections": {
    "key-takeaway": {
      "desc": "页面头部和 4 个 KPI 总览卡片",
      "required": true,
      "hideable": false
    },
    "core-finding-1": {
      "desc": "3 个周期活动趋势仪表盘",
      "required": true,
      "hideable": true
    },
    "core-finding-2": {
      "desc": "存储类型分段条形图和热门文件列表",
      "required": true,
      "hideable": true
    }
  },
  "supportedChartTypes": [
    "gauge-ring",
    "gauge-half",
    "custom-segmented"
  ],
  "schema": {
    "editableText": {
      "type": "array",
      "selector": "[data-editable=\"true\"]",
      "desc": "所有可编辑文字均带 data-slot 和 contenteditable"
    },
    "charts": {
      "type": "array",
      "selector": "[data-chart-type]",
      "desc": "ECharts 图表容器和 DOM 分段条形图容器"
    },
    "sections": {
      "type": "array",
      "selector": "[data-section]",
      "desc": "Dashboard 核心模块"
    },
    "textSlots": [
      "header.title",
      "header.meta",
      "kpi1.title",
      "kpi1.value",
      "kpi1.trend",
      "kpi2.title",
      "kpi2.value",
      "kpi2.trend",
      "kpi3.title",
      "kpi3.value",
      "kpi3.trend",
      "kpi4.title",
      "kpi4.value",
      "kpi4.trend",
      "trend1.title",
      "trend1.d_value",
      "trend1.u_value",
      "trend1.compare",
      "trend2.title",
      "trend2.d_value",
      "trend2.u_value",
      "trend2.compare",
      "trend3.title",
      "trend3.d_value",
      "trend3.u_value",
      "trend3.compare",
      "usage.title",
      "files.title",
      "file1.name",
      "file1.dl",
      "file1.view",
      "file2.name",
      "file2.dl",
      "file2.view",
      "file3.name",
      "file3.dl",
      "file3.view"
    ]
  },
  "chartModules": [
    { "id": "chart-kpi-1", "type": "gauge-ring", "section": "key-takeaway", "titleSlot": "kpi1.title", "styleNote": "Blue KPI gauge" },
    { "id": "chart-kpi-2", "type": "gauge-ring", "section": "key-takeaway", "titleSlot": "kpi2.title", "styleNote": "Green KPI gauge" },
    { "id": "chart-kpi-3", "type": "gauge-ring", "section": "key-takeaway", "titleSlot": "kpi3.title", "styleNote": "Light blue KPI gauge" },
    { "id": "chart-kpi-4", "type": "gauge-ring", "section": "key-takeaway", "titleSlot": "kpi4.title", "styleNote": "Orange KPI gauge" },
    { "id": "chart-trend-1", "type": "gauge-half", "section": "core-finding-1", "titleSlot": "trend1.title" },
    { "id": "chart-trend-2", "type": "gauge-half", "section": "core-finding-1", "titleSlot": "trend2.title" },
    { "id": "chart-trend-3", "type": "gauge-half", "section": "core-finding-1", "titleSlot": "trend3.title" },
    { "id": "segmented-bar", "type": "custom-segmented", "section": "core-finding-2", "titleSlot": "usage.title" }
  ],
  "sampleData": {
    "texts": {
      "header.title": "Analytics & Report",
      "header.meta": "Insights into your storage usage and file activity",
      "kpi1.title": "Total Storage",
