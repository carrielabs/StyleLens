      "trend1.compare": "+0.08% Compared to past year",
      "trend2.title": "Activity Trends (February)",
      "trend2.d_value": "120",
      "trend2.u_value": "09,793",
      "trend2.compare": "+0.10% Compared to january",
      "trend3.title": "Activity Trends (March)",
      "trend3.d_value": "200",
      "trend3.u_value": "11,793",
      "trend3.compare": "+0.20% Compared to February",
      "usage.title": "Storage Usages by Type",
      "files.title": "Top Accessed Files This Month",
      "file1.name": "Pitch_Deck_2025.pdf",
      "file1.dl": "12 downloads",
      "file1.view": "48 views",
      "file2.name": "Brand_Guidelines.docx",
      "file2.dl": "8 downloads",
      "file2.view": "32 views",
      "file3.name": "Campaign_Banners.pdf",
      "file3.dl": "8 downloads",
      "file3.view": "32 views"
    },
    "charts": {
      "chart-kpi-1": { "value": 37 },
      "chart-kpi-2": { "value": 45 },
      "chart-kpi-3": { "value": 50 },
      "chart-kpi-4": { "value": 20 },
      "chart-trend-1": { "percent": 15, "label": "0.12%", "subLabel": "135 of 1108" },
      "chart-trend-2": { "percent": 18, "label": "0.14%", "subLabel": "120 of 1000" },
      "chart-trend-3": { "percent": 25, "label": "0.20%", "subLabel": "200 of 1500" },
      "segmented-bar": {
        "groups": [
          { "color": "#3B82F6", "count": 40, "height": "16px" },
          { "color": "#10B981", "count": 30, "height": "20px" },
          { "color": "#8B5CF6", "count": 30, "height": "24px" },
          { "color": "#F59E0B", "count": 20, "height": "14px" }
        ]
      }
    }
  },
  "hiddenBehaviors": {
    "emptySection": "hide-section",
    "emptyChart": "hide-chart-container"
  },
  "slotLimits": {
    "header-title": 20,
    "header-meta": 40,
    "kpi-title": 20,
    "kpi-value": 24,
    "kpi-trend": 24,
    "trend-title": 32,
    "trend-value": 16,
    "trend-compare": 36,
    "file-name": 36,
    "file-stat": 18
  },
  "llmInjectionRules": [
    "所有新增可编辑文字必须同时包含 data-editable=\"true\"、contenteditable=\"true\" 和 data-slot。",
    "图表容器 ID 必须保持 chart-* 或 segmented-bar 格式。",
    "替换 KPI 图表数据时优先修改 initKpiGauge 调用中的 value，不触碰布局和样式代码。",
    "替换趋势图表数据时优先修改 initTrendGauge 调用中的 percent、label 和 subLabel。",
    "保持浅色毛玻璃、弥散光背景和蓝绿橙紫数据色，不添加厚重卡片阴影。"
  ],
