{
  "id": "dashboard-11-saas-growth-health-report",
  "name": "SaaS Growth Health Report SaaS 增长健康度数据报告看板",
  "templateName": "SaasGrowthHealthReportDashboardTemplate",
  "version": "1.0.0",
  "description": "面向 SaaS 业务增长与健康度述职的高管数据报告模板，覆盖 NDR、产品渗透、客户成功、AI 人效、系统稳定性、私域增长、裂变、内容营销、客户分层和 ROI。",
  "pageTypes": [
    "data-report",
    "executive-dashboard",
    "business-review",
    "saas-analytics"
  ],
  "styleTags": [
    "saas-growth",
    "health-report",
    "executive-dashboard",
    "light-dashboard",
    "echarts"
  ],
  "deliveryType": "scrolling-site",
  "interactionMode": "editable-dashboard",
  "contentCapacity": "high",
  "bestFor": [
    "SaaS 经营复盘",
    "年度述职",
    "NDR 留存分析",
    "产品渗透分析",
    "客户成功健康度分析"
  ],
  "requiredRuntime": [
    "Tailwind CSS CDN",
    "ECharts CDN",
    "Lucide Icons CDN",
    "Vanilla JavaScript"
  ],
  "editableCapabilities": {
    "textEdit": true,
    "inlineContentEditable": true,
    "chartDataDrive": true,
    "excelSlotMapping": true,
    "showHideSections": true
  },
  "supportedSections": {
    "page-title": {
      "desc": "报告标题与摘要",
      "required": true,
      "hideable": false
    },
    "key-takeaways": {
      "desc": "核心高管洞察",
      "required": true,
      "hideable": true
    },
    "kpi-overview": {
      "desc": "核心 KPI 概览",
      "required": true,
      "hideable": false
    },
    "ndr-trend": {
      "desc": "NDR 净收入留存趋势",
      "required": true,
      "hideable": true
    },
    "product-penetration": {
      "desc": "产品渗透率矩阵",
      "required": true,
      "hideable": true
    },
    "customer-health": {
      "desc": "客户成功健康度",
      "required": true,
      "hideable": true
    },
    "ai-empowerment": {
      "desc": "AI 赋能人效分析",
      "required": true,
      "hideable": true
    },
    "system-stability": {
      "desc": "系统稳定性与 SLA",
      "required": true,
      "hideable": true
    },
    "private-domain-growth": {
      "desc": "私域增长与客单价",
      "required": true,
      "hideable": true
    },
    "viral-k-factor": {
      "desc": "裂变效应与 K-factor",
      "required": true,
      "hideable": true
    },
    "content-marketing": {
      "desc": "内容营销资产",
      "required": true,
      "hideable": true
    },
    "customer-stratification": {
      "desc": "客户分层分析",
      "required": true,
      "hideable": true
    },
    "channel-roi": {
      "desc": "ROI 投资效能矩阵",
      "required": true,
      "hideable": true
    }
  },
  "schema": {
    "editableText": {
      "type": "array",
      "selector": "[data-editable=\"true\"]",
      "desc": "所有可编辑文字，已补齐 data-slot 和 contenteditable"
    },
    "charts": {
      "type": "array",
      "selector": "[id^=\"chart-\"]",
      "desc": "ECharts 图表容器"
    }
  },
  "slotLimits": {
    "page-title": 28,
    "section-title": 36,
    "metric-label": 28,
    "metric-value": 16,
    "insight-text": 140
  },
  "audit": {
    "sourceFileArchived": true,
    "topNavigationRemoved": true,
    "dataEditableHasContenteditable": true,
    "dataSlotsAdded": true,
    "previewGenerated": false,
    "previewNote": "低性能模式下未生成 preview.png。"
  },
  "editorTheme": {
    "defaultColor": "#8baaa0",
    "presets": [
      "#8baaa0",
      "#b06262",
      "#3370ff",
      "#7c3aed",
      "#f97316",
      "#111827"
    ],
    "targets": {
      "colorSelectors": [
        "[class*=\"text-sage\"]",
        "[class*=\"text-wine\"]"
      ],
      "backgroundSelectors": [
        "[class*=\"bg-sage\"]",
        "[class*=\"bg-wine\"]"
      ],
      "borderSelectors": [
        "[class*=\"border-sage\"]",
        "[class*=\"border-wine\"]"
      ]
    }
  }
}
