      "kpi_profit": { "value": "¥3.2 亿", "label": "净利润", "trend": "+15.2%", "trendType": "up" },
      "kpi_efficiency": { "value": "8.5%", "label": "运营费用率", "trend": "-1.2pp", "trendType": "down_good" },
