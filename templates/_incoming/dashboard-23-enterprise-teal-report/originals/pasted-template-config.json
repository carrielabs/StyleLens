{
  "id": "enterprise_report_emerson_style_v1",
  "name": "企业级经营分析报告模板 (Emerson风格)",
  "Description": "基于Emerson ESG报告风格设计的专业数据分析模板，强调清晰的叙事结构和克制的视觉表达，适合用于年度总结、经营复盘等正式场合。",
  "pageTypes": ["Dashboard", "Report"],
  "language": "zh-CN",
  "styleTags": ["Corporate", "Professional", "Clean", "Infographic", "Teal"],
  "supportedSections": [
    { "id": "section_key_takeaway", "name": "关键结论摘要", "maxCharts": 3 },
    { "id": "section_core_finding_1", "name": "核心发现 1：运营效率", "maxCharts": 4 },
    { "id": "section_core_finding_2", "name": "核心发现 2：市场格局", "maxCharts": 4 },
    { "id": "section_core_finding_3", "name": "核心发现 3：风险展望", "maxCharts": 4 }
  ],
  "supportedChartTypes": [
    "kpi_card",
    "line_chart",
    "bar_chart_vertical",
    "bar_chart_horizontal",
    "stacked_bar_chart",
    "area_chart",
    "donut_chart",
    "radar_chart",
    "heatmap",
    "scatter_chart",
    "waterfall_chart",
    "ranking_list"
  ],
  "editableCapabilities": {
    "text": true,
    "chartData": true,
    "chartConfig": true
  },
  "schema": {
    "text": [
      { "key": "text.report_title", "label": "报告主标题", "default": "2024年度企业经营与战略发展分析报告" },
      { "key": "text.key_takeaway_summary", "label": "关键结论摘要", "default": "本年度核心业务保持稳健增长，总营收同比提升 12.5%，主要得益于新产品线在 Q3 的成功爆发。运营效率指标显著改善，但供应链成本波动仍是当前面临的主要外部风险。未来需重点关注高毛利市场的渗透率提升。" },
      { "key": "text.finding_1_title", "label": "核心发现1标题", "default": "核心发现 1：运营效率与成本结构优化" },
      { "key": "text.finding_1_analysis", "label": "核心发现1分析", "default": "通过数字化转型举措，核心生产环节的人均产出率在下半年实现了 8% 的环比增长。成本结构方面，固定成本占比进一步压缩，但原材料价格波动导致可变成本在 Q4 有所回升，需持续关注采购策略的优化。" },
      { "key": "text.finding_2_title", "label": "核心发现2标题", "default": "核心发现 2：市场份额与主要增长来源" },
      { "key": "text.finding_2_analysis", "label": "核心发现2分析", "default": "我们在华东区域的市场份额首次突破 35%，确立了区域领先地位。从收入构成来看，A 类核心产品依然是营收基石，贡献了近 60% 的份额；B 类创新业务增速最快，同比增长超过 45%，是未来的核心增长引擎。" },
      { "key": "text.finding_3_title", "label": "核心发现3标题", "default": "核心发现 3：综合能力评估与风险预警" },
      { "key": "text.finding_3_analysis", "label": "核心发现3分析", "default": "基于多维能力评估模型，我们在「产品研发」和「客户服务」维度表现优异，但在「渠道掌控力」方面略显薄弱，低于行业平均水平。风险雷达显示，库存周转率下降带来的资金占用风险处于黄色预警区域，需加快去库存节奏。" }
    ],
    "sampleData": {
