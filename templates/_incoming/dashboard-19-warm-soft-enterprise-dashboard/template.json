      ],
      "backgroundSelectors": [
        "[class*=\"bg-yellow\"]",
        "[class*=\"bg-orange\"]",
        "[class*=\"bg-red\"]",
        "[class*=\"bg-teal\"]",
        "[class*=\"bg-[#FFFBEB]\"]"
      ],
      "borderSelectors": [
        "[class*=\"border-orange\"]",
        "[class*=\"border-slate\"]"
      ]
    }
  }
}
